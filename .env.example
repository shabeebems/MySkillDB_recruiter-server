# Server Configuration
PORT=5000

# Database Configuration
# MongoDB connection string (MongoDB Atlas or local MongoDB)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# Environment
# Options: development, staging, production
NODE_ENV=development

# JWT Secrets
# Generate strong random strings for these secrets
# You can use: openssl rand -hex 32
ACCESS_TOKEN_SECRET=your-access-token-secret-here
REFRESH_TOKEN_SECRET=your-refresh-token-secret-here

# Frontend URL
# Used for CORS configuration
FRONTEND_URL=http://localhost:5173

# Google Cloud / Vertex AI Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_CLOUD_MODEL=gemini-2.5-flash

# Service Account Credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project-id.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=123456789012345678901
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Firebase Admin SDK (Non-sensitive - set in workflow)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-service-account@your-project.iam.gserviceaccount.com

# Firebase Admin SDK (Sensitive - store in GCP Secret Manager)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n"

# Password encryption key (Sensitive - store in GCP Secret Manager)
PASSWORD_ENCRYPTION_KEY=your-password-encryption-key-here

# SMTP Configuration (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-email@example.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM="Your App Name <noreply@example.com>"
